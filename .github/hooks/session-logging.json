{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "mkdir -p logs/copilot && cat >> logs/copilot/session-start.ndjson",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "mkdir -p logs/copilot && cat >> logs/copilot/user-prompts.ndjson",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "mkdir -p logs/copilot && cat >> logs/copilot/session-end.ndjson",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "errorOccurred": [
      {
        "type": "command",
        "bash": "mkdir -p logs/copilot && cat >> logs/copilot/errors.ndjson",
        "cwd": ".",
        "timeoutSec": 10
      }
    ]
  }
}